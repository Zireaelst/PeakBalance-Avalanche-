# PeakBalance — Environment Variables
# Copy this file to .env and fill in your values

# Deployer private key (no 0x prefix)
PRIVATE_KEY=

# Avalanche Fuji Testnet RPC
FUJI_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc

# Avalanche Mainnet RPC (optional)
MAINNET_RPC_URL=https://api.avax.network/ext/bc/C/rpc

# Snowtrace API Key (for contract verification)
SNOWTRACE_API_KEY=

# Etherscan-compatible API key for Routescan (Fuji verification)
ROUTESCAN_API_KEY=
