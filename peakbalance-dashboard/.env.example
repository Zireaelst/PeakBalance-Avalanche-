# PeakBalance Dashboard — Environment Variables
# Copy to .env.local and fill in values

# ═══ Avalanche RPC ═══
NEXT_PUBLIC_AVALANCHE_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc
NEXT_PUBLIC_CHAIN_ID=43113

# ═══ WalletConnect ═══
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id

# ═══ Contract Addresses (update after deployment) ═══
NEXT_PUBLIC_CONSTRAINT_ENGINE=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_PEAK_VAULT=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_AGENT_REGISTRY=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_PEAK_CONTROLLER=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_ORACLE_CONSUMER=0x0000000000000000000000000000000000000000
